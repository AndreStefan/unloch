{
  "$schema": "https://railway.com/railway.schema.json",
  "services": {
    "backend": {
      "source": {
        "repo": "AndreStefan/unloch",
        "branch": "main"
      },
      "build": {
        "dockerfilePath": "backend/Dockerfile.railway",
        "buildContext": "."
      },
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 60,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "variables": {
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}",
        "REDIS_URL": "${{Redis.REDIS_URL}}",
        "JWT_SECRET": {"generator": "secret", "length": 32},
        "JWT_ACCESS_EXPIRY": "15m",
        "JWT_REFRESH_EXPIRY": "7d",
        "AI_SERVICE_URL": "${{ai-service.RAILWAY_PRIVATE_DOMAIN}}:8000",
        "ANTHROPIC_API_KEY": "${{shared.ANTHROPIC_API_KEY}}",
        "NODE_ENV": "production",
        "PORT": "4000",
        "CORS_ORIGIN": "${{dashboard.RAILWAY_PUBLIC_DOMAIN}}"
      }
    },
    "ai-service": {
      "source": {
        "repo": "AndreStefan/unloch",
        "branch": "main",
        "rootDirectory": "ai-service"
      },
      "variables": {
        "ANTHROPIC_API_KEY": "${{shared.ANTHROPIC_API_KEY}}",
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}"
      }
    },
    "dashboard": {
      "source": {
        "repo": "AndreStefan/unloch",
        "branch": "main"
      },
      "build": {
        "dockerfilePath": "dashboard/Dockerfile",
        "buildContext": "dashboard",
        "buildArgs": {
          "VITE_API_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}"
        }
      },
      "variables": {
        "PORT": "3000"
      }
    }
  }
}
